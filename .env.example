# CustomerOpsAgent environment template
# Copy this file to .env for local development.
# Never commit real API keys.

# ============================================================
# Frontend public API base URL
# This value is safe to expose because it is only the backend URL.
# ============================================================
VITE_API_BASE_URL=http://127.0.0.1:8000

# ============================================================
# Backend CORS
# Add local Vite dev URL and deployed Vercel frontend URL.
# ============================================================
CUSTOMEROPS_ALLOWED_ORIGINS=http://localhost:5173,https://customer-ops-agent.vercel.app

# ============================================================
# LLM timeout
# ============================================================
CUSTOMEROPS_LLM_TIMEOUT_SECONDS=30

# ============================================================
# DeepSeek profile
# Frontend only sends llm_profile=deepseek.
# Real key must be configured on backend/Render only.
# ============================================================
CUSTOMEROPS_LLM_DEEPSEEK_BASE_URL=
CUSTOMEROPS_LLM_DEEPSEEK_API_KEY=
CUSTOMEROPS_LLM_DEEPSEEK_MODEL=

# ============================================================
# Doubao profile
# Frontend only sends llm_profile=doubao.
# Real key must be configured on backend/Render only.
# ============================================================
CUSTOMEROPS_LLM_DOUBAO_BASE_URL=
CUSTOMEROPS_LLM_DOUBAO_API_KEY=
CUSTOMEROPS_LLM_DOUBAO_MODEL=

# ============================================================
# Mimo profile
# Frontend only sends llm_profile=mimo.
# Real key must be configured on backend/Render only.
# Fill these values in Render Environment, not in frontend.
# ============================================================
CUSTOMEROPS_LLM_MIMO_BASE_URL=
CUSTOMEROPS_LLM_MIMO_API_KEY=
CUSTOMEROPS_LLM_MIMO_MODEL=
